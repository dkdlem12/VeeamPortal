# ──────────────────────────────────────────────────────────────
# Veeam Backup Portal 환경 설정
# 복사: cp .env.example .env  → 값 입력 후 저장
# ──────────────────────────────────────────────────────────────

# [1] PostgreSQL DB 직접 연결 (Veeam v12, 권장)
VEEAM_DB_TYPE=postgresql
VEEAM_DB_HOST=192.168.1.10       # Veeam 서버 IP
VEEAM_DB_PORT=5432
VEEAM_DB_NAME=VeeamBackup
VEEAM_DB_USER=veeam_readonly
VEEAM_DB_PASSWORD=your_password

# [2] Veeam REST API (DB 접근 불가 시 폴백)
VEEAM_API_HOST=https://192.168.1.10:9419
VEEAM_API_USER=administrator
VEEAM_API_PASSWORD=
VEEAM_API_VERIFY_SSL=false

# [3] JWT 인증
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# [4] Grafana (선택)
GRAFANA_URL=http://192.168.1.20:3000
GRAFANA_API_KEY=

# [5] 앱
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
